FROM oven/bun:1.3.13 AS deps

WORKDIR /workspace

COPY package.json bun.lock ./
COPY apps/server/package.json apps/server/package.json
COPY apps/web/package.json apps/web/package.json

RUN bun install --frozen-lockfile --filter './apps/server' --production

FROM oven/bun:1.3.13 AS runtime

ENV NODE_ENV=production
ENV PORT=4000

WORKDIR /workspace

COPY --from=deps /workspace/node_modules ./node_modules
COPY --from=deps /workspace/package.json ./package.json
COPY --from=deps /workspace/apps/server/node_modules ./apps/server/node_modules
COPY --from=deps /workspace/apps/server/package.json ./apps/server/package.json
COPY apps/server/src ./apps/server/src

WORKDIR /workspace/apps/server

EXPOSE 4000

CMD ["bun", "run", "start"]
